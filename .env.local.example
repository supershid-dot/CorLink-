# CorLink — local development public frontend configuration TEMPLATE.
#
# Copy this file to `.env.local` at the repo root (already gitignored —
# see .gitignore) and fill in your own personal/local Supabase project's
# public values, then run: scripts/set-frontend-environment.sh local
#
# Only the public Supabase project URL and anon/publishable key belong
# here — NEVER a service-role key or any other secret.
SUPABASE_URL="REPLACE_WITH_LOCAL_SUPABASE_URL"
SUPABASE_ANON_KEY="REPLACE_WITH_LOCAL_SUPABASE_ANON_KEY"
