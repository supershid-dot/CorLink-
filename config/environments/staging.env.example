# CorLink — staging environment public frontend configuration TEMPLATE.
#
# Copy this file to `config/environments/staging.env` (gitignored — see
# .gitignore) and fill in the two values below before running
# scripts/set-frontend-environment.sh staging. Never commit the filled-in
# file: staging.env is intentionally excluded from version control so a
# real staging URL/key can never end up merged into a branch that also
# serves production (see docs/23-staging-frontend-configuration.md).
#
# Only the public Supabase project URL and anon/publishable key belong
# here — NEVER a service-role key or any other secret.
SUPABASE_URL="REPLACE_WITH_STAGING_SUPABASE_URL"
SUPABASE_ANON_KEY="REPLACE_WITH_STAGING_SUPABASE_ANON_KEY"
